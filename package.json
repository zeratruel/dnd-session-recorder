{
  "name": "dnd-session-recorder",
  "version": "1.0.0",
  "description": "Discord bot that records D&D sessions and transcribes them locally",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "transcribe": "python transcriber/transcribe.py",
    "dev": "node --watch src/bot.js"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@snazzah/davey": "^0.1.11",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "libsodium-wrappers": "^0.8.4",
    "node-notifier": "^10.0.1",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
